# ============================================================
# Cấu hình backend Open edX — FILE MẪU
# Copy file này thành .env.local rồi điền giá trị thật
# KHÔNG BAO GIỜ commit .env.local vào Git
# ============================================================

# URL LMS chính
VITE_OPENEDX_LMS_URL=

# URL Studio/CMS — dùng để redirect admin/mentor
VITE_OPENEDX_CMS_URL=

# OAuth2 Application credentials (tạo qua Django Admin)
VITE_OPENEDX_CLIENT_ID=
VITE_OPENEDX_CLIENT_SECRET=

# Thời gian (ms) refresh token trước khi hết hạn (khuyến nghị: 300000 = 5 phút)
VITE_TOKEN_REFRESH_BUFFER_MS=300000

# Timeout (ms) cho API calls (khuyến nghị: 30000 = 30 giây)
VITE_API_TIMEOUT_MS=30000

# Browser API URL. Production behind Cloudflare/reverse proxy should leave this empty
# so the app calls same-origin /api instead of an http:// backend URL.
VITE_API_BASE_URL=

# Private backend target for server.js /api proxy. This is used only by Node/PM2.
API_BACKEND_URL=http://127.0.0.1:<backend-port>

# Admin frontend URL. Dev: http://localhost:3000 | Production: /admin or empty.
VITE_ADMIN_URL=
